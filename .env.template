# VECTRA Frontend Environment Variables Template
# Copy this file to .env and .env.local and update with your actual values
# This template includes all required variables for production deployment

# ============================================================================
# NEXT.JS CONFIGURATION
# ============================================================================

# Disable Next.js telemetry and analytics
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Backend API URL for server-side requests (internal Docker network)
# Docker: Use service name 'backend' (http://backend:8000)
# Local development: Use localhost (http://localhost:8000)
# Important: This is used for server-side API calls and should be internal network
API_URL=http://backend:8000

# Backend API URL for client-side requests (browser access)
# Docker/Public: Use actual hostname or IP accessible from browser
# Local development: Use localhost (http://localhost:8000)
# Important: This is used in browser and should be publicly accessible
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis connection URL for server-side caching
# Format: redis://[password]@[host]:[port]/[database]
# Docker: Use service name 'redis' (redis://redis:6379/0)
# Local: Use localhost (redis://localhost:6379/0)
# With password: redis://:password@host:port/0
REDIS_URL=redis://redis:6379/0
